# Core runtime
POC_AUTOMATION_DB=.tmp/poc_automation.sqlite
POC_AUTOMATION_ARTIFACT_DIR=.tmp/artifacts
POC_AUTOMATION_AGENT=heuristic
POC_AUTOMATION_RUNNER=mock
POC_SEARCH_RUNNER_PARALLELISM=3
POC_AGENT_TRIAL_REPLICATES=3
POC_AGENT_TRIAL_REPLICATE_MIN_DELTA_MEAN=0
POC_AGENT_TRIAL_REPLICATE_MIN_WORST_DELTA=0
POC_AGENT_TRIAL_REPLICATE_MAX_REGRESSION_COUNT=0
# OpenRouter v3 human-reference search:
# POC_AUTOMATION_AGENT=deepagent-human-ref
# POC_AUTOMATION_RUNNER=deepagent

# Real PoC application API runner (--runner http)
POC_APP_BASE_URL=http://localhost:8080
POC_APP_API_KEY=
POC_APP_TIMEOUT_SECONDS=120
POC_APP_POLL_INTERVAL_SECONDS=2
POC_APP_MAX_POLLS=60

# Langfuse self-host integration
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# DeepAgent target runner (--runner deepagent)
# This is the evaluation target application substitute. It reads the materialized
# procedure CSV and evidence bundle, then returns judgement/rationale/citations.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-max
OPENROUTER_TEMPERATURE=0
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_RETRIES=2
OPENROUTER_APP_URL=http://localhost/poc-automation
OPENROUTER_APP_TITLE=PoC Automation
POC_TARGET_AGENT_MAX_CSV_CHARS=12000
POC_TARGET_AGENT_MAX_EVIDENCE_CHARS=30000

# Optional OpenRouter routing JSON, e.g. {"data_collection":"deny"}
# OPENROUTER_PROVIDER_JSON={"data_collection":"deny"}
# OPENROUTER_ROUTE=fallback

# DeepAgent tuning candidate generator (--agent deepagent / deepagent-human-ref)
# Uses OPENROUTER_API_KEY by default. Override these when candidate generation
# should use a different Qwen model, temperature, routing, or title.
POC_CANDIDATE_AGENT_MODEL=qwen/qwen3-max
POC_CANDIDATE_AGENT_TEMPERATURE=0.2
POC_CANDIDATE_AGENT_MAX_TOKENS=4096
POC_CANDIDATE_AGENT_MAX_RETRIES=2
POC_CANDIDATE_AGENT_TIMEOUT_SECONDS=120
POC_CANDIDATE_AGENT_APP_TITLE=PoC Automation Candidate Generator
# POC_CANDIDATE_AGENT_OPENROUTER_PROVIDER_JSON={"data_collection":"deny"}
# POC_CANDIDATE_AGENT_OPENROUTER_ROUTE=fallback
